# ASR Service Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# Application Settings
# ============================================
APP_NAME="ASR Service"
APP_VERSION="1.0.0"
DEBUG=false

# ============================================
# Server Settings
# ============================================
HOST=0.0.0.0
PORT=8000
WORKERS=1

# ============================================
# Port Mapping (host ports)
# ============================================
API_PORT=8010
UI_PORT=3010
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ============================================
# Database (PostgreSQL)
# ============================================
POSTGRES_USER=asr
POSTGRES_PASSWORD=asr
POSTGRES_DB=asr
DATABASE_URL=postgresql+asyncpg://asr:asr@postgres:5432/asr
DATABASE_POOL_SIZE=10

# ============================================
# Redis
# ============================================
REDIS_URL=redis://redis:6379/0

# ============================================
# Object Storage (MinIO)
# ============================================
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=asr-storage
MINIO_SECURE=false

# ============================================
# Security
# ============================================
# Generate a strong JWT secret: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-256-bit-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_REQUESTS_PER_HOUR=1000

# ============================================
# ASR Model Settings
# ============================================
# Directory inside the container where models are mounted
WHISPER_MODELS_DIR=/models

# Host path to models directory (mounted into container as /models)
HOST_MODELS_DIR=/mnt/aetherpro/models/audio

# Model to preload on startup (model name or path relative to WHISPER_MODELS_DIR)
# For faster-whisper models downloaded with `hf download`, use the path:
#   Systran/faster-whisper-large-v3  (relative to /models)
# For models downloaded via faster-whisper's auto-download, use the name:
#   large-v3, medium, small, base, tiny
WHISPER_PRELOAD_MODELS=large-v3
WHISPER_DEFAULT_MODEL=large-v3
WHISPER_COMPUTE_TYPE=float16
WHISPER_DEVICE=cuda

# ============================================
# GPU Settings
# ============================================
# Which GPU device to use (0-indexed)
CUDA_VISIBLE_DEVICES=0
GPU_DEVICE_ID=0

# ============================================
# HuggingFace Cache
# ============================================
# Host path for HuggingFace model cache
HOST_HF_CACHE_DIR=/mnt/aetherpro/hf-cache
# Container path (don't change unless you know what you're doing)
HF_HOME=/mnt/hf-cache

# ============================================
# Processing Limits
# ============================================
MAX_FILE_SIZE_MB=500
MAX_DURATION_SECONDS=7200
DEFAULT_RETENTION_DAYS=7
SYNC_MAX_DURATION_SECONDS=30

# ============================================
# VAD Settings
# ============================================
VAD_ENABLED=true
VAD_THRESHOLD=0.5
VAD_MIN_SPEECH_DURATION_MS=250

# ============================================
# Chunking Settings
# ============================================
CHUNK_LENGTH_SECONDS=30
CHUNK_OVERLAP_SECONDS=5

# ============================================
# Celery Worker
# ============================================
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_WORKER_CONCURRENCY=1

# ============================================
# Webhook Settings
# ============================================
WEBHOOK_TIMEOUT_SECONDS=30
WEBHOOK_MAX_RETRIES=3

# ============================================
# Observability
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=json
METRICS_ENABLED=true
TRACING_ENABLED=false

# ============================================
# Grafana (monitoring profile)
# ============================================
GRAFANA_PASSWORD=admin
