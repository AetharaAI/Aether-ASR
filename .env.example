# ASR Service Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# Application Settings
# ============================================
APP_NAME="ASR Service"
APP_VERSION="1.0.0"
DEBUG=false

# ============================================
# Server Settings
# ============================================
HOST=0.0.0.0
PORT=8000
WORKERS=1

# ============================================
# Database (PostgreSQL)
# ============================================
DATABASE_URL=postgresql+asyncpg://asr:asr@postgres:5432/asr
DATABASE_POOL_SIZE=10

# ============================================
# Redis
# ============================================
REDIS_URL=redis://redis:6379/0

# ============================================
# Object Storage (MinIO)
# ============================================
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=asr-storage
MINIO_SECURE=false

# ============================================
# Security
# ============================================
# Generate a strong JWT secret: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-256-bit-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_REQUESTS_PER_HOUR=1000

# ============================================
# ASR Model Settings
# ============================================
WHISPER_MODELS_DIR=/models
WHISPER_DEFAULT_MODEL=base
WHISPER_COMPUTE_TYPE=float16
WHISPER_DEVICE=cuda
WHISPER_PRELOAD_MODELS=tiny,base

# ============================================
# Processing Limits
# ============================================
MAX_FILE_SIZE_MB=500
MAX_DURATION_SECONDS=7200
DEFAULT_RETENTION_DAYS=7
SYNC_MAX_DURATION_SECONDS=30

# ============================================
# VAD Settings
# ============================================
VAD_ENABLED=true
VAD_THRESHOLD=0.5
VAD_MIN_SPEECH_DURATION_MS=250

# ============================================
# Chunking Settings
# ============================================
CHUNK_LENGTH_SECONDS=30
CHUNK_OVERLAP_SECONDS=5

# ============================================
# Celery Worker
# ============================================
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_WORKER_CONCURRENCY=2

# ============================================
# Webhook Settings
# ============================================
WEBHOOK_TIMEOUT_SECONDS=30
WEBHOOK_MAX_RETRIES=3

# ============================================
# Observability
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=json
METRICS_ENABLED=true
TRACING_ENABLED=false
